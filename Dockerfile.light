FROM mcr.microsoft.com/devcontainers/base:debian

# Install bun as vscode user (the default devcontainer user)
USER vscode
RUN curl -fsSL https://bun.sh/install | bash

ENV BUN_INSTALL="/home/vscode/.bun"
ENV PATH="$BUN_INSTALL/bin:$PATH"

# Install global tools
RUN bun add -g convex

# Symlink bun into system PATH for non-interactive SSH sessions
USER root
RUN ln -sf /home/vscode/.bun/bin/bun /usr/local/bin/bun \
    && ln -sf /home/vscode/.bun/bin/bunx /usr/local/bin/bunx
