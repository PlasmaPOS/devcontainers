FROM mcr.microsoft.com/devcontainers/base:debian

# Install Node system-wide (needed for Playwright install as root + AI CLIs)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

# Install AI CLIs as root — lands in /usr/local/bin, available to all users + non-interactive SSH
RUN npm install -g @anthropic-ai/claude-code @openai/codex

# Install bun as vscode user
USER vscode
RUN curl -fsSL https://bun.sh/install | bash

ENV BUN_INSTALL="/home/vscode/.bun"
ENV PATH="$BUN_INSTALL/bin:$PATH"

# Switch to root for system-level installs
USER root

# Install Playwright + Chromium
ENV PLAYWRIGHT_BROWSERS_PATH="/home/vscode/.cache/ms-playwright"
RUN npx playwright install --with-deps chromium \
    && chown -R vscode:vscode /home/vscode/.cache/ms-playwright

# Install Java (required by Android SDK)
RUN apt-get update && apt-get install -y default-jdk-headless && rm -rf /var/lib/apt/lists/*

# Install Android SDK
RUN mkdir -p /opt/android-sdk/cmdline-tools \
    && cd /tmp \
    && curl -fsSL "https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip" -o cmdline-tools.zip \
    && unzip -q cmdline-tools.zip \
    && mv cmdline-tools /opt/android-sdk/cmdline-tools/latest \
    && rm cmdline-tools.zip

ENV ANDROID_HOME=/opt/android-sdk
ENV ANDROID_SDK_ROOT=/opt/android-sdk
ENV PATH="$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$ANDROID_HOME/emulator"

RUN yes | sdkmanager --licenses > /dev/null 2>&1 || true \
    && sdkmanager "platform-tools" "platforms;android-34" "system-images;android-34;google_apis;x86_64" "emulator"

# Create default emulator AVD
RUN echo "no" | avdmanager create avd -n test-device -k "system-images;android-34;google_apis;x86_64" --device "pixel_6" --force

# Install global tools as vscode user
USER vscode
RUN bun add -g convex agent-device

# Symlink bun into system PATH for non-interactive SSH sessions
USER root
RUN ln -sf /home/vscode/.bun/bin/bun /usr/local/bin/bun \
    && ln -sf /home/vscode/.bun/bin/bunx /usr/local/bin/bunx
